# ==============================================================
# JudgeSense environment template
# Copy this file to `.env` and fill in your API keys.
# DO NOT commit the real `.env` file — it is gitignored.
# ==============================================================

# OpenAI — for GPT-4o-mini judge
OPENAI_API_KEY=sk-...

# HuggingFace — for Llama 3 8B judge (free tier works for this paper)
HF_TOKEN=hf_...

# Mistral — for Mistral-7B judge (free tier available)
MISTRAL_API_KEY=...

# Optional: set to override defaults
# JUDGESENSE_OUTPUT_DIR=./data/results/raw_outputs
# JUDGESENSE_RUNS_PER_PAIR=3
# JUDGESENSE_TEMPERATURE=0.0
